{
  "name": "paper-trade",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @paper-trade/api --filter @paper-trade/web dev",
    "dev:api": "corepack pnpm --filter @paper-trade/api dev",
    "dev:web": "corepack pnpm --filter @paper-trade/web dev",
    "coverage": "corepack pnpm --filter @paper-trade/core test:coverage && corepack pnpm --filter @paper-trade/markets test:coverage && corepack pnpm --filter @paper-trade/api test:coverage",
    "test": "corepack pnpm -r test",
    "typecheck": "corepack pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
